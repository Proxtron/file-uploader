<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add File</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include("components/header") %>
    <h1>Add File</h1>
    <form action="/file/add-file" method="POST" enctype="multipart/form-data">
        <input type="number" id="parentFolderId" name="parentFolderId" 
            value="<%- parentFolderId %>" required hidden>
        <div class="form-row">
            <label for="file">File</label>
            <input type="file" id="file" name="file" required>
        </div>
        <button type="submit">Add File</button>
    </form>
</body>
</html>