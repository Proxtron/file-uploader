<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>File Uploader</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include("components/header") %>
    <h1>File Uploader</h1>

    <% if(locals.user) { %>
        <p>Welcome, <%= user.username %></p>
        <% if(user.files && user.files.length > 0) { %>
            <h2>Uploaded Files</h2>
            <table class="file-table">
                <thead>
                    <th class="file-table-heading">Filename</th>
                </thead>
                <tbody>
                    <% for(const file of user.files) { %>
                        <tr class="file-table-row" onclick="window.location='/file/view/<%- file.id %>'">
                            <td class="file-table-cell"><%= file.originalFilename %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        <% } else { %>
            <p>You have not uploaded any files yet.</p>
        <% } %>
    <% } else { %>
        <p>You must log in to access your file system.</p>
    <% } %>
</body>
</html>